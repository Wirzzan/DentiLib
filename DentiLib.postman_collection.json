	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Création compte administrateur",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const statusCode = pm.response.code;",
									"const response = pm.response.json();",
									"",
									"pm.test(\"Réponse JSON\", () => pm.response.to.be.json);",
									"",
									"if (statusCode === 201 || statusCode === 409) {",
									"    pm.test(\"Création admin — succès ou email déjà utilisé\", () => {",
									"        pm.expect([201, 409]).to.include(statusCode);",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"{{firstName}}\",\n  \"lastName\": \"{{lastName}}\",\n  \"email\": \"{{emailCreation}}\",\n  \"password\": \"{{passwordCreation}}\"\n}"
						},
						"url": "{{BASE-URL}}/api/user/registerAdmin"
					}
				},
				{
					"name": "Connexion administrateur",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const statusCode = pm.response.code;",
									"const response = pm.response.json();",
									"",
									"pm.test(\"Réponse JSON\", () => pm.response.to.be.json);",
									"",
									"if (statusCode === 200) {",
									"    pm.environment.set(\"tokenAdmin\", response.token);",
									"    pm.test(\"Connexion admin réussie avec token JWT\", () => {",
									"        pm.expect(response.token).to.be.a(\"string\");",
									"        pm.expect(response.role).to.eql(\"ADMIN\");",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{emailLogin}}\",\n  \"password\": \"{{passwordLogin}}\"\n}"
						},
						"url": "{{BASE-URL}}/api/user/login"
					}
				}
			]
		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Création compte dentiste par admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const statusCode = pm.response.code;",
									"const response = pm.response.json();",
									"",
									"if (statusCode === 201) {",
									"    pm.environment.set(\"dentisteId\", response.user._id);",
									"}",
									"",
									"pm.test(\"Création dentiste — 201 ou 409\", () => {",
									"    pm.expect([201, 409]).to.include(statusCode);",
									"});",
									"",
									"if (statusCode === 201) {",
									"    pm.test(\"Rôle DENTISTE\", () => {",
									"        pm.expect(response.user.role).to.eql(\"DENTISTE\");",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Dentiste\",\n  \"lastName\": \"Postman\",\n  \"email\": \"{{emailDentiste}}\",\n  \"password\": \"{{passwordDentiste}}\",\n  \"role\": \"DENTISTE\",\n  \"siret\": \"12345678900011\"\n}"
						},
						"url": "{{BASE-URL}}/admin/user/createAccount"
					}
				},
				{
					"name": "Création compte prothésiste par admin",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (!pm.environment.get(\"dentisteId\")) {",
									"    throw new Error(\"dentisteId manquant — exécuter la création dentiste d'abord ou réinitialiser la BDD\");",
									"}"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const statusCode = pm.response.code;",
									"const response = pm.response.json();",
									"",
									"if (statusCode === 201) {",
									"    pm.environment.set(\"prothesisteId\", response.prothesiste._id);",
									"}",
									"",
									"pm.test(\"Création prothésiste — 201 ou 409\", () => {",
									"    pm.expect([201, 409]).to.include(statusCode);",
									"});",
									"",
									"if (statusCode === 201) {",
									"    pm.test(\"Prothésiste lié au dentiste\", () => {",
									"        pm.expect(response.prothesiste.role).to.eql(\"PROTHESISTE\");",
									"        pm.expect(String(response.prothesiste.associatedUserId)).to.eql(String(pm.environment.get(\"dentisteId\")));",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Prothésiste\",\n  \"lastName\": \"Postman\",\n  \"email\": \"{{emailProthesiste}}\",\n  \"password\": \"{{passwordProthesiste}}\",\n  \"role\": \"PROTHESISTE\",\n  \"dentisteId\": \"{{dentisteId}}\"\n}"
						},
						"url": "{{BASE-URL}}/admin/user/createAccount"
					}
				},
				{
					"name": "Liste de tous les utilisateurs",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Liste utilisateurs — HTTP 200\", () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Réponse est un tableau\", () => {",
									"    pm.expect(pm.response.json()).to.be.an(\"array\");",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
						"url": "{{BASE-URL}}/admin/user/allUsers"
					}
				},
				{
					"name": "Modification compte dentiste par admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Modification dentiste — HTTP 200\", () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Prénom mis à jour\", () => {",
									"    pm.expect(pm.response.json().user.firstName).to.eql(\"DentisteMod\");",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"DentisteMod\",\n  \"lastName\": \"Postman\",\n  \"email\": \"{{emailDentiste}}\",\n  \"siret\": \"12345678900011\"\n}"
						},
						"url": "{{BASE-URL}}/admin/user/updateAccount/{{dentisteId}}"
					}
				}
			]
		},
