# MongoDB (encore utilisé par les contrôleurs — retiré à l'étape D)
DB_URL=mongodb://localhost:27017/dentilib

# MySQL (Sequelize — étape A)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dentilib
DB_USER=root
DB_PASSWORD=

# Créer les tables au démarrage (true après config XAMPP)
DB_SYNC=false

# JWT
JWT_SECRET=change_me
